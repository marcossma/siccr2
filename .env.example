# Banco de dados PostgreSQL
DB_HOST=localhost
DB_USER=postgres
DB_PASSWORD=sua_senha_aqui
DB_NAME=siccr
DB_PORT=5432

# Servidor
PORT=15000

# JWT - use uma string longa e aleatória (mínimo 32 caracteres)
